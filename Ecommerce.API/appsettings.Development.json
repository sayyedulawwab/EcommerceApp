{
  "Serilog": {
    "Using": [ "Serilog.Sinks.File", "Serilog.Formatting.Compact", "Serilog.Enrichers.Thread", "Serilog.Enrichers.Environment" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithThreadName",
      "WithMachineName"
    ],
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.json",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 90,
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/errorlog-.json",
          "rollingInterval": "Day",
          "restrictedToMinimumLevel": "Error",
          "retainedFileCountLimit": 90,
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      }
    ]
  },
  "Otlp": {
    "LogsEndpoint": "http://localhost:14318/v1/logs",
    "TracesEndpoint": "http://localhost:14318/v1/traces",
    "MetricsEndpoint": "http://localhost:14318/v1/metrics"
  },
  "Jwt": {
    "Audience": "Ecommerce",
    "Issuer": "Ecommerce",
    "SecretKey": "dont-tell-anyone!dont-tell-anyone!"
  },
  "ConnectionStrings": {
    "Database": "Host=database-postgres;Port=5432;Database=ecommercedb;Username=postgres;Password=postgres;",
    "Redis": "cache-redis:6379"
  }
}
